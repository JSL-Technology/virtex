# =============================================================================
# VARIABLES DE ENTORNO — ERP-API (NESTJS)
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before starting the app.
# =============================================================================

# -----------------------------------------------------------------------------
# RECAPTCHA
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=your_recaptcha_v3_site_key
RECAPTCHA_V3_SECRET_KEY=your_recaptcha_v3_secret_key

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:4200
CORS_ORIGIN=http://localhost:4200
APP_NAME="Billio"
# Public base URL of the API (scheme + host + prefix). Used to build OAuth/SSO callback URLs
# that are registered in the identity providers. Must be reachable by the browser.
API_PUBLIC_URL=http://localhost:3000/api/v1

# -----------------------------------------------------------------------------
# DATABASE (POSTGRESQL) [REQUIRED]
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=erp
DB_SYNCHRONIZE=false

# -----------------------------------------------------------------------------
# AUTHENTICATION (JWT) [ALL REQUIRED IN PRODUCTION]
# Generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Each secret MUST be different from all others (key separation — NIST SP 800-57).
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET
JWT_2FA_TEMP_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET
JWT_PREVERIFY_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET

JWT_EXPIRATION_TIME=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_REMEMBER_ME_EXPIRATION=30d
JWT_RESET_PASSWORD_EXPIRATION=15m

# -----------------------------------------------------------------------------
# ENCRYPTION [REQUIRED IN PRODUCTION]
# Used to encrypt IP addresses stored in refresh_tokens (AES-256-GCM).
# -----------------------------------------------------------------------------
ENCRYPTION_SECRET=REPLACE_WITH_STRONG_SECRET
AUTH_SALT=REPLACE_WITH_UNIQUE_SALT

# -----------------------------------------------------------------------------
# MAIL
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="Billio"

# -----------------------------------------------------------------------------
# THROTTLE / RATE LIMITING
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=10
AUTH_THROTTLE_LIMIT=5
AUTH_THROTTLE_TTL=60000

# -----------------------------------------------------------------------------
# REDIS [REQUIRED IN PRODUCTION for distributed throttling & caching]
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# STRIPE [REQUIRED for payment features]
# Use sk_test_... (secret key), NOT pk_test_... (publishable key)!
# Get keys at: https://dashboard.stripe.com/apikeys
# Get webhook secret from: https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_ENDPOINT_SECRET

# -----------------------------------------------------------------------------
# SOCIAL / OIDC LOGIN — shared
# -----------------------------------------------------------------------------
# Secret used to encrypt+sign the short-lived OAuth handshake cookie (state/nonce/PKCE).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to ENCRYPTION_SECRET if unset; MUST be set explicitly in production.
OAUTH_STATE_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET

# -----------------------------------------------------------------------------
# GOOGLE OIDC (social login)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# -----------------------------------------------------------------------------
# MICROSOFT OIDC (social login — Microsoft Entra ID / Azure AD, v2.0 endpoint)
# Register an app at: https://entra.microsoft.com (App registrations).
# Redirect URI (Web platform) must match MICROSOFT_CALLBACK_URL exactly.
# MICROSOFT_TENANT:
#   common        -> any work/school account + personal Microsoft accounts (default)
#   organizations -> any work/school (Azure AD) account
#   consumers     -> personal Microsoft accounts only
#   <tenant-guid> -> a single specific tenant (strict issuer validation)
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_CALLBACK_URL=http://localhost:3000/api/v1/auth/microsoft/callback
MICROSOFT_TENANT=common

# -----------------------------------------------------------------------------
# ENTERPRISE SSO (Phase 2) — per-tenant OIDC IdPs (Okta, Entra, Ping, Auth0...)
# These are configured per organization in the database (IdentityProvider), NOT here.
# Each customer brings their own issuer/clientId/clientSecret via the admin UI.
# The IdP client secret is encrypted at rest using ENCRYPTION_SECRET.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# TWILIO (SMS for OTP and MFA) [REQUIRED for phone verification]
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# -----------------------------------------------------------------------------
# AWS S3 (File Storage)
# -----------------------------------------------------------------------------
AWS_S3_BUCKET_NAME=your_s3_bucket_name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# -----------------------------------------------------------------------------
# WEB PUSH (VAPID)
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# -----------------------------------------------------------------------------
# SWAGGER (Protect Swagger UI in non-production environments)
# -----------------------------------------------------------------------------
SWAGGER_USER=admin
SWAGGER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# XE CURRENCY API
# -----------------------------------------------------------------------------
XE_API_ID=your_xe_api_id
XE_API_KEY=your_xe_api_key
BASE_CURRENCY=USD
