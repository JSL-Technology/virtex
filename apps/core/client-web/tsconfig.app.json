{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "rootDir": "../../..",
    "types": [],
    "lib": ["es2022", "dom"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts",
    "../../../libs/shared/util-auth/src/**/*.ts",
    "../../../libs/shared/types/src/**/*.ts"
  ],
  "exclude": [
    "jest.config.ts",
    "src/test-setup.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "jest.config.cts"
  ]
}